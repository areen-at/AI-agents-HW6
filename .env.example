# Copy this file to .env for local private values.
# Do not commit real .env files.

# Optional MCP authentication tokens for deployed/local protected servers.
COP_MCP_TOKEN=
THIEF_MCP_TOKEN=
OPPONENT_COP_MCP_TOKEN=
OPPONENT_THIEF_MCP_TOKEN=

# Gmail API paths. Root filenames are safe only because both are explicitly gitignored.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GMAIL_DELIVERY_RECEIPT_FILE=artifacts/reports/gmail_delivery_receipt.json

# Optional future model provider keys. The Phase 1 baseline does not need these.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
